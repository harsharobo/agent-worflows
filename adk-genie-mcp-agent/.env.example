# =============================================================================
# Databricks Configuration
# =============================================================================
# DATABRICKS_PROFILE=demo
DATABRICKS_HOST=https://databrick_host_url

# Databricks authentication — choose ONE of the options below:
#
# Option 1: Personal Access Token (PAT)
# Generate at: User Settings > Developer > Access Tokens > Generate New Token
DATABRICKS_TOKEN=dapi<your-token-here>
#
# Option 2: OAuth M2M (Service Principal client credentials)
# Create a service principal and OAuth secret in the Databricks account console,
# then grant it access to the workspace and Genie Space.
DATABRICKS_CLIENT_ID=<service-principal-application-id>
DATABRICKS_CLIENT_SECRET=<oauth-secret>

# Databricks AI/BI Genie Space ID - found in the URL when you open a Genie Space:
# https://<host>/genie/spaces/<GENIE_SPACE_ID>
GENIE_SPACE_ID=<your-genie-space-id>

# =============================================================================
# Google Cloud / Vertex AI Configuration
# =============================================================================
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=TRUE

# # GCS bucket for Vertex AI Agent Engine staging (must exist)
# STAGING_BUCKET=gs://your-staging-bucket

# =============================================================================
# ADK Configuration (alternative: Google AI Studio)
# =============================================================================
# Set to FALSE and provide GOOGLE_API_KEY to use Google AI Studio instead of Vertex AI
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_API_KEY=AIza<your-api-key>
